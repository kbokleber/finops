# ==============================================================================
# CONFIGURAÇÃO DO AMBIENTE - FinOps Dashboard
# ==============================================================================
# Este é um arquivo de EXEMPLO. Copie para .env e ajuste conforme seu ambiente.
# IMPORTANTE: O arquivo .env NÃO deve ser versionado no Git (já está no .gitignore)
# ==============================================================================

# ------------------------------------------------------------------------------
# Ambiente de Execução
# ------------------------------------------------------------------------------
# Valores: development | production
FLASK_ENV=development

# URL base do seu domínio (sem https:// e sem porta)
# DEV: devmonitorfinops.service.com.br
# PRD: monitorfinops.service.com.br
SERVER_DOMAIN=devmonitorfinops.service.com.br

# ------------------------------------------------------------------------------
# Autenticação Azure AD
# ------------------------------------------------------------------------------
# Habilitar login com Microsoft Azure AD (true ou false)
ENABLE_AZURE_AUTH=false

# Credenciais do Azure AD Application
# Obtenha no portal Azure: https://portal.azure.com -> Azure Active Directory -> App registrations
AZURE_CLIENT_ID=seu-client-id-aqui
AZURE_CLIENT_SECRET=seu-client-secret-aqui
AZURE_TENANT_ID=seu-tenant-id-aqui

# ------------------------------------------------------------------------------
# Segurança Flask
# ------------------------------------------------------------------------------
# Gere uma chave única usando: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=gere-uma-chave-secreta-unica-aqui

# ------------------------------------------------------------------------------
# Banco de Dados PostgreSQL
# ------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=svc_finops
DB_PASSWORD=sua-senha-do-banco
DB_NAME=finopsdatabase
