# ==============================================================================
# FinOps - Template consolidado de variaveis de ambiente
# ==============================================================================
# Copie este arquivo para .env (local) ou use as variaveis no Coolify Cloud.
# NUNCA commite o arquivo .env com valores reais.
#
# Para gerar senhas seguras:
#   openssl rand -hex 24   # POSTGRES_PASSWORD / RABBITMQ_PASS
#   openssl rand -hex 32   # SECRET_KEY
# ==============================================================================

# ------------------------------------------------------------------------------
# Postgres (usado pelo dashboard e workers)
# ------------------------------------------------------------------------------
POSTGRES_DB=finopsdatabase
POSTGRES_USER=svc_finops
POSTGRES_PASSWORD=

# Conexao lida por finops_celery/settings.py (montada pelo servico env-init no
# docker-compose.prod.yml a partir das vars acima).
CONEXAO_DB_URL=postgres
CONEXAO_DB_PORT=5432

# Conexao lida por dashboard/config.py (Flask)
DB_HOST=postgres
DB_PORT=5432
DB_USER=svc_finops
DB_PASSWORD=
DB_NAME=finopsdatabase

# ------------------------------------------------------------------------------
# RabbitMQ (broker Celery - nome do servico no compose: rabbitmq)
# ------------------------------------------------------------------------------
RABBITMQ_USER=guest
RABBITMQ_PASS=

# ------------------------------------------------------------------------------
# Flask / Dashboard
# ------------------------------------------------------------------------------
FLASK_ENV=production
SECRET_KEY=
ENABLE_AZURE_AUTH=false
SERVER_DOMAIN=

# ------------------------------------------------------------------------------
# Azure AD (preencher apenas se ENABLE_AZURE_AUTH=true)
# ------------------------------------------------------------------------------
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=

# ------------------------------------------------------------------------------
# Provedores Cloud (opcional - usar para coleta via Celery tasks)
# ------------------------------------------------------------------------------
# OCI - Oracle Cloud Infrastructure
# OCI_USER_OCID=
# OCI_TENANCY_OCID=
# OCI_COMPARTMENT_OCID=
# OCI_FINGERPRINT=
# OCI_KEY_FILE=/path/to/api_key.pem

# AWS
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# Azure
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# GCP
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT_ID=

# ==============================================================================
# Valores reais (NAO COLOCAR AQUI - ver SECRETS.txt)
# ==============================================================================
# Os valores historicos do projeto foram movidos para o arquivo SECRETS.txt
# que esta no .gitignore. Guarde-o no gerenciador de senhas da equipe.
