# Template de variaveis para o Coolify Cloud.
# Configure esses valores em: Coolify > Service > Environment Variables
# NAO faca commit deste arquivo com valores reais.

# --- Postgres ---
POSTGRES_DB=finopsdatabase
POSTGRES_USER=svc_finops
# POSTGRES_PASSWORD=  # OBRIGATORIO - gerar com: openssl rand -hex 24

# --- RabbitMQ ---
RABBITMQ_USER=guest
# RABBITMQ_PASS=     # OBRIGATORIO - gerar com: openssl rand -hex 16

# --- Flask / Dashboard ---
SECRET_KEY=        # OBRIGATORIO - gerar com: openssl rand -hex 32
FLASK_ENV=production
ENABLE_AZURE_AUTH=false

# --- Observacoes ---
# O servico `env-init` no docker-compose.prod.yml gera automaticamente o
# arquivo /finops/finops_celery/.env (lido por settings.py) a partir das
# variaveis acima. Voce nao precisa setar CONEXAO_DB_URL, CONEXAO_DB_SENHA,
# REDIS_DB_URL etc. manualmente - elas sao derivadas.
#
# Se quiser adicionar credenciais de cloud providers (OCI, AWS, Azure, GCP),
# adicione-as como variaveis extras no Coolify e ajuste o bloco env-init
# no compose para inclui-las no .env gerado.
